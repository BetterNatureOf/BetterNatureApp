rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    // Role hierarchy used across web + app:
    //   super_admin > admin > volunteer / partner / member
    // Actual roles used across the app:
    //   member  - default volunteer
    //   chapter_president (or chapter_pres) - runs one chapter
    //   executive - org-wide c-suite (highest)
    //   restaurant - food donor portal
    // Legacy 'admin' / 'super_admin' kept for backwards compat with
    // any seed accounts that predate the role rename.
    function isExec() {
      return isSignedIn() && role() in ['executive', 'admin', 'super_admin'];
    }
    function isAdmin() {
      return isSignedIn() && role() in ['executive', 'admin', 'super_admin'];
    }
    function isPresident() {
      return isSignedIn() && role() in ['chapter_president', 'chapter_pres', 'executive', 'admin', 'super_admin'];
    }
    function isSuperAdmin() {
      return isSignedIn() && role() in ['executive', 'super_admin'];
    }

    // ── users ──
    // Anyone signed in can read member profiles (for leaderboard, signups).
    // The user themselves can update non-privileged fields. Privileged
    // fields (role, member_status, verification_status, restaurant_status)
    // can only be changed by execs — OR by the user themselves if and
    // only if their auth email is on the BetterNature founder domain.
    // This closes the rule-level hole where a regular member could call
    // setDoc({role:'executive'}) on their own doc via the JS SDK.
    // EXPLICIT founder allowlist. Mirrors src/services/founder.js.
    // Anyone NOT on this list — including other @betternatureofficial.org
    // staff — cannot self-promote and must be promoted by an exec
    // through Manage Members.
    function isFounderToken() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
             'satvik.koya@betternatureofficial.org',
           ];
    }
    function touchesPrivilegedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role','member_status','verification_status','restaurant_status']);
    }
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      // Anyone can edit their own non-privileged fields (name, phone,
      // address, prefs). Privileged fields (role, member_status, etc.)
      // require an exec, OR the writer being a founder editing their
      // own doc. Non-founder members literally cannot escalate
      // themselves no matter what JS they run.
      allow update: if isExec()
        || (isSelf(uid) && !touchesPrivilegedFields())
        || (isSelf(uid) && isFounderToken());
      allow delete: if isAdmin();
    }

    // ── chapters ──
    match /chapters/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── events ──
    match /events/{id} {
      allow read: if true;
      allow create, update: if isExec();
      allow delete: if isAdmin();
    }

    // ── event_signups ──
    match /event_signups/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isExec() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isExec() || (isSignedIn() && resource.data.user_id == request.auth.uid);
    }

    // ── pickups ──
    // Restaurants create their own pickups when they post surplus.
    // Volunteers update them as they claim / arrive / deliver.
    // Execs can do anything for the org-wide queue management.
    function isRestaurantUser() {
      return isSignedIn() && role() == 'restaurant';
    }
    match /pickups/{id} {
      allow read: if isSignedIn();
      // Restaurant creates a pickup whose restaurant_id matches
      // either their own uid or their linked restaurant_id, and
      // status starts at 'available'. Execs can also seed pickups.
      allow create: if isExec() || (
        isRestaurantUser()
        && request.resource.data.restaurant_id in [request.auth.uid, get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurant_id]
        && request.resource.data.status == 'available'
      );
      // Volunteer state transitions are scoped to the claimer.
      // Restaurant can update their own pickups (cancel, edit photo).
      // Execs override either.
      allow update: if isExec()
        || (isSignedIn() && resource.data.restaurant_id in [request.auth.uid, get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurant_id])
        || (isSignedIn() && (resource.data.claimed_by == request.auth.uid || request.resource.data.claimed_by == request.auth.uid));
      allow delete: if isAdmin();
    }

    // ── restaurants ──
    // A new restaurant signup creates their own doc (with
    // status:'pending' and user_id matching their auth uid) so the
    // approval queue picks it up. Execs manage everything else.
    match /restaurants/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isExec();
    }

    // ── donations ──
    // Users can see their own; exec sees all.
    match /donations/{id} {
      allow read: if isExec() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── notifications ──
    // Reads/updates are scoped to the recipient. Creates allowed for any
    // signed-in user: the pickup workflow generates them as side effects
    // of legitimate actions (createPickup notifies chapter members,
    // setPickupEnroute notifies the restaurant, completePickup notifies
    // both). Notifications carry no privileges — only a recipient + a
    // human-readable body — so the worst-case abuse is one user spamming
    // another, which we accept for now and can rate-limit later if needed.
    match /notifications/{id} {
      allow read, update: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isSelf(resource.data.user_id) || isAdmin();
    }

    // ── member_activity ──
    match /member_activity/{id} {
      allow read: if isSignedIn();
      allow write: if isExec();
    }

    // ── announcements ──
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isExec();
    }

    // ── org_metrics ──
    match /org_metrics/{id} {
      allow read: if true;
      allow write: if isExec();
    }

    // ── org_stats (live counters that drive website ticker + app impact) ──
    // Public read so the marketing site can show real-time numbers without
    // an auth round-trip. Writes only happen from inside the app via
    // bumpOrgStats() — restricted to signed-in users so anonymous traffic
    // can't inflate the counters.
    match /org_stats/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── animals_helped, badges, user_badges, member_of_month, checklist_progress ──
    match /animals_helped/{id}    { allow read: if true; allow write: if isExec(); }
    match /badges/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /user_badges/{id}       { allow read: if isSignedIn(); allow write: if isExec(); }
    match /member_of_month/{id}   { allow read: if true; allow write: if isExec(); }
    match /checklist_progress/{id}{ allow read: if isSignedIn(); allow write: if isExec(); }

    // ── tax_receipts ──
    // Public read so a restaurant can open the receipt URL we email them
    // without signing in. The doc id is unguessable (Firestore-generated)
    // so it functions as a capability token. Only execs can mint or edit;
    // nobody deletes — receipt history is immutable for audit.
    match /tax_receipts/{id} {
      allow read: if true;
      // Receipts are minted from completePickup() which runs as the
      // volunteer (member role). Anyone signed in can create; nobody
      // can edit or delete an issued receipt — it's audit history.
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── sms_outbox ──
    // Queue read/written by the Cloud Function dispatcher. Signed-in
    // users can enqueue (they're already authenticated to post a pickup,
    // claim, or complete — that's when we add to this queue). Nobody
    // reads or edits except the server function via admin SDK.
    match /sms_outbox/{id} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── fridges (community fridge network) ──
    // Public read so the marketing site can render fridge pins on the map
    // without auth. Only admins manage the network (add/edit/deactivate
    // fridges); volunteers and restaurants merely read.
    match /fridges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── admin_invites (website /admin.html) ──
    // Only super admins create/list/revoke; signup flow needs to read+update
    // its own doc to consume a one-time code, so we allow read by anyone
    // who knows the email (codes are still verified server-side via
    // consumeInviteCode before promotion).
    match /admin_invites/{email} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── admin_audit (edit history) ──
    // Admins can read; any signed-in admin can append; nobody edits past entries.
    match /admin_audit/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── site_content (admin panel saves) ──
    // Anyone can read (public site reads its own content); admins write.
    match /site_content/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny-by-default for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
