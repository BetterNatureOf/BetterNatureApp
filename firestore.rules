rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    // Multi-role: a user can hold extra roles beyond their primary
    // `role`. Defaults to [] when the field is missing.
    function rolesArray() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('roles', []);
    }
    // True if the writer holds ANY of `targets` either as their
    // primary `role` or anywhere in their supplemental `roles[]`.
    function hasAnyRole(targets) {
      return isSignedIn()
        && (role() in targets || rolesArray().hasAny(targets));
    }
    // Role hierarchy used across web + app:
    //   super_admin > admin > volunteer / partner / member
    // Actual roles used across the app:
    //   member  - default volunteer
    //   chapter_president (or chapter_pres) - runs one chapter
    //   executive - org-wide c-suite (highest)
    //   restaurant - food donor portal
    // Legacy 'admin' / 'super_admin' kept for backwards compat with
    // any seed accounts that predate the role rename.
    function isExec()       { return hasAnyRole(['executive', 'admin', 'super_admin']); }
    function isAdmin()      { return hasAnyRole(['executive', 'admin', 'super_admin']); }
    function isPresident()  { return hasAnyRole(['chapter_president', 'chapter_pres', 'executive', 'admin', 'super_admin']); }
    function isSuperAdmin() { return hasAnyRole(['executive', 'super_admin']); }

    // The signed-in user's chapter_id (from their user doc). Used to
    // enforce that a chapter president can only edit objects in their
    // own chapter — not another chapter's events/announcements/etc.
    function myChapterId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.chapter_id;
    }
    // True when the writer is a president AND the chapterId in
    // question matches their own chapter. Execs bypass — they can
    // act across all chapters.
    function isPresOfChapter(chapterId) {
      return isExec()
        || (isSignedIn()
            && hasAnyRole(['chapter_president', 'chapter_pres'])
            && chapterId != null
            && chapterId == myChapterId());
    }

    // ── users ──
    // Anyone signed in can read member profiles (for leaderboard, signups).
    // The user themselves can update non-privileged fields. Privileged
    // fields (role, member_status, verification_status, restaurant_status)
    // can only be changed by execs — OR by the user themselves if and
    // only if their auth email is on the BetterNature founder domain.
    // This closes the rule-level hole where a regular member could call
    // setDoc({role:'executive'}) on their own doc via the JS SDK.
    // EXPLICIT founder allowlist. Mirrors src/services/founder.js.
    // Anyone NOT on this list — including other @betternatureofficial.org
    // staff — cannot self-promote and must be promoted by an exec
    // through Manage Members.
    function isFounderToken() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
             'satvik.koya@betternatureofficial.org',
           ];
    }
    function touchesPrivilegedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role','roles','member_status','verification_status','restaurant_status']);
    }
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      // Anyone can edit their own non-privileged fields (name, phone,
      // address, prefs). Privileged fields (role, member_status, etc.)
      // require an exec, OR the writer being a founder editing their
      // own doc. Non-founder members literally cannot escalate
      // themselves no matter what JS they run.
      allow update: if isExec()
        || (isSelf(uid) && !touchesPrivilegedFields())
        || (isSelf(uid) && isFounderToken());
      allow delete: if isAdmin();
    }

    // ── chapters ──
    // Execs can create/delete any chapter and edit any chapter. A
    // chapter president can ONLY edit their own chapter doc (the one
    // whose id matches their user.chapter_id) — never a sibling
    // chapter's name, location, or status.
    match /chapters/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isExec()
        || (isSignedIn()
            && hasAnyRole(['chapter_president', 'chapter_pres'])
            && id == myChapterId());
    }

    // ── chapter_applications ──
    // Submitted from the signup-flow "Start a chapter" screen, which
    // means the writer is often NOT yet authenticated. Allow open
    // create with the required shape; exec reviews and approves to
    // materialize the real /chapters/{id} doc.
    match /chapter_applications/{id} {
      allow read: if isExec();
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.proposed_name is string
                    && request.resource.data.city is string;
      allow update, delete: if isExec();
    }

    // ── chapter_join_requests ──
    // Existing users asking to switch into / join a chapter. Set on
    // the user's request; exec approves which then flips
    // users/{uid}.chapter_id and marks the request approved.
    match /chapter_join_requests/{id} {
      allow read: if isExec()
                  || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.user_id == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update, delete: if isExec();
    }

    // ── events ──
    // Exec creates/edits/deletes anything; chapter pres creates and
    // edits ONLY events stamped with their own chapter_id, and
    // cannot reassign an event from their chapter to another by
    // changing chapter_id on update.
    match /events/{id} {
      allow read: if true;
      allow create: if isPresOfChapter(request.resource.data.chapter_id);
      allow update: if isPresOfChapter(resource.data.chapter_id)
                    && isPresOfChapter(request.resource.data.chapter_id);
      allow delete: if isAdmin()
                    || (isSignedIn()
                        && hasAnyRole(['chapter_president', 'chapter_pres'])
                        && resource.data.chapter_id == myChapterId());
    }

    // ── event_signups ──
    match /event_signups/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isExec() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isExec() || (isSignedIn() && resource.data.user_id == request.auth.uid);
    }

    // ── pickups ──
    // Restaurants create their own pickups when they post surplus;
    // volunteers progress them through the claim/enroute/complete
    // states; execs can do anything for org-wide queue management.
    //
    // Helper: does the signed-in user own this restaurant_id? True
    // if the rid equals their auth uid OR matches the restaurant_id
    // we stamped on their user doc at signup. We re-fetch the user
    // doc inside the rule so even brand-new restaurant accounts
    // work without a fresh sign-in.
    function pickupRid() { return request.resource.data.restaurant_id; }
    function existingRid() { return resource.data.restaurant_id; }
    function userRid() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurant_id;
    }
    match /pickups/{id} {
      allow read: if isSignedIn();

      // Create: exec OR any signed-in user whose auth uid (or
      // mirrored restaurant_id) matches the pickup's restaurant_id.
      // We deliberately don't require role=='restaurant' on the rule
      // — the role string can drift during signup (member ->
      // restaurant migration etc.). The id-match is the real check.
      allow create: if isExec() || (
        isSignedIn() && pickupRid() != null
        && (pickupRid() == request.auth.uid || pickupRid() == userRid())
      );

      // Update: exec, original poster, or the volunteer who's
      // currently claimed the pickup.
      allow update: if isExec()
        || (isSignedIn() && existingRid() != null
            && (existingRid() == request.auth.uid || existingRid() == userRid()))
        || (isSignedIn() && resource.data.claimed_by == request.auth.uid)
        || (isSignedIn() && request.resource.data.claimed_by == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ── restaurants ──
    // A new restaurant signup creates their own doc (with
    // status:'pending' and user_id matching their auth uid) so the
    // approval queue picks it up. Execs manage everything else.
    match /restaurants/{id} {
      allow read: if true;
      // Two legit paths:
      //  A) Public restaurant signup form — the signed-up user
      //     writes their own record with user_id == auth.uid and
      //     status == 'pending' so the queue picks it up.
      //  B) Exec onboarding — an exec creates the record on behalf
      //     of a partner (church community garden, offline signup,
      //     backfill of promoted members, etc.) with any status.
      // Without (B), backfillRestaurantDocs + updateUserRole
      // silently failed rules and the partner never appeared on
      // Manage Restaurants.
      allow create: if isExec()
        || (isSignedIn()
            && request.resource.data.user_id == request.auth.uid
            && request.resource.data.status == 'pending');
      allow update, delete: if isExec();
    }

    // ── donations ──
    // Users can see their own; exec sees all.
    match /donations/{id} {
      allow read: if isExec() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── notifications ──
    // Reads/updates are scoped to the recipient. Creates allowed for any
    // signed-in user: the pickup workflow generates them as side effects
    // of legitimate actions (createPickup notifies chapter members,
    // setPickupEnroute notifies the restaurant, completePickup notifies
    // both). Notifications carry no privileges — only a recipient + a
    // human-readable body — so the worst-case abuse is one user spamming
    // another, which we accept for now and can rate-limit later if needed.
    match /notifications/{id} {
      allow read, update: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isSelf(resource.data.user_id) || isAdmin();
    }

    // ── notifications_outbox ──
    // Drained by the Cloudflare dispatcher worker, which sends each
    // doc out as email/push. Open create so unauth signup-flow
    // surfaces (chapter applications, partner forms) can drop a
    // receipt; read/delete reserved for the dispatcher's service
    // account and execs.
    match /notifications_outbox/{id} {
      allow create: if true;
      allow read, update, delete: if isExec();
    }

    // ── member_activity ──
    match /member_activity/{id} {
      allow read: if isSignedIn();
      allow write: if isExec();
    }

    // ── announcements ──
    // Exec broadcasts org-wide; chapter pres can broadcast ONLY to
    // their own chapter (must stamp chapter_id matching their user
    // doc on create, and can only edit/delete their own chapter's
    // announcements).
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create: if isPresOfChapter(request.resource.data.chapter_id);
      allow update: if isPresOfChapter(resource.data.chapter_id)
                    && isPresOfChapter(request.resource.data.chapter_id);
      allow delete: if isAdmin()
                    || (isSignedIn()
                        && hasAnyRole(['chapter_president', 'chapter_pres'])
                        && resource.data.chapter_id == myChapterId());
    }

    // ── org_metrics ──
    match /org_metrics/{id} {
      allow read: if true;
      allow write: if isExec();
    }

    // ── org_stats (live counters that drive website ticker + app impact) ──
    // Public read so the marketing site can show real-time numbers without
    // an auth round-trip. Writes only happen from inside the app via
    // bumpOrgStats() — restricted to signed-in users so anonymous traffic
    // can't inflate the counters.
    match /org_stats/{id} {
      allow read: if true;
      // bumpOrgStats is called as a side effect of legitimate writes
      // (pickup complete, event check-in, donation). The doc only
      // carries running counters — no PII, no privileges. To stop
      // a logged-in user from inflating the ticker via the JS
      // console, restrict writes to ONLY the known counter fields
      // (no arbitrary keys) and gate destructive resets behind
      // exec. Any signed-in user can bump; only an exec can clear.
      allow update: if isSignedIn()
        && request.resource.data.keys().hasOnly(
             ['meals','lbs','individuals','co2','water','events','hours','volunteers','chapters','updated_at']
           );
      allow create, delete: if isExec();
    }

    // ── animals_helped, badges, user_badges, member_of_month, checklist_progress ──
    match /animals_helped/{id}    { allow read: if true; allow write: if isExec(); }
    match /badges/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /user_badges/{id}       { allow read: if isSignedIn(); allow write: if isExec(); }
    match /member_of_month/{id}   { allow read: if true; allow write: if isExec(); }
    match /checklist_progress/{id}{ allow read: if isSignedIn(); allow write: if isExec(); }

    // ── tax_receipts ──
    // Public read so a restaurant can open the receipt URL we email them
    // without signing in. The doc id is unguessable (Firestore-generated)
    // so it functions as a capability token. Only execs can mint or edit;
    // nobody deletes — receipt history is immutable for audit.
    match /tax_receipts/{id} {
      allow read: if true;
      // Receipts must be tied to a real /pickups/{id} that the
      // CURRENT signed-in user actually delivered (claimed_by ==
      // auth.uid) and that's in 'completed' status. Without this
      // anyone signed in could mint a forged receipt for any
      // restaurant via the JS SDK. Execs can mint anything (manual
      // backfills, paper receipts). Nobody edits or deletes — the
      // collection is immutable audit history.
      allow create: if isExec()
        || (isSignedIn()
            && request.resource.data.pickup_id is string
            && exists(/databases/$(database)/documents/pickups/$(request.resource.data.pickup_id))
            && get(/databases/$(database)/documents/pickups/$(request.resource.data.pickup_id)).data.claimed_by == request.auth.uid
            && get(/databases/$(database)/documents/pickups/$(request.resource.data.pickup_id)).data.status == 'completed');
      allow update, delete: if false;
    }

    // ── sms_outbox ──
    // Queue read/written by the Cloud Function dispatcher. Signed-in
    // users can enqueue (they're already authenticated to post a pickup,
    // claim, or complete — that's when we add to this queue). Nobody
    // reads or edits except the server function via admin SDK.
    match /sms_outbox/{id} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── fridges (community fridge network) ──
    // Public read so the marketing site can render fridge pins on the map
    // without auth. Only admins manage the network (add/edit/deactivate
    // fridges); volunteers and restaurants merely read.
    match /fridges/{id} {
      allow read: if true;
      // Exec writes anywhere. A chapter pres can add/edit fridges
      // ONLY for their own chapter (chapter_id on create/update must
      // match the writer's user.chapter_id, and the existing chapter
      // on edits must match too — no moving a fridge into another
      // chapter from the pres view).
      allow create: if isExec()
                    || isPresOfChapter(request.resource.data.chapter_id);
      allow update: if isExec()
                    || (isPresOfChapter(resource.data.chapter_id)
                        && isPresOfChapter(request.resource.data.chapter_id));
      allow delete: if isAdmin();
    }

    // ── admin_invites (website /admin.html) ──
    // Only super admins create/list/revoke; signup flow needs to read+update
    // its own doc to consume a one-time code, so we allow read by anyone
    // who knows the email (codes are still verified server-side via
    // consumeInviteCode before promotion).
    match /admin_invites/{email} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── admin_audit (edit history) ──
    // Admins can read; any signed-in admin can append; nobody edits past entries.
    match /admin_audit/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── site_content (admin panel saves) ──
    // Anyone can read (public site reads its own content); admins write.
    match /site_content/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny-by-default for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
