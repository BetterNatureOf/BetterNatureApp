# BetterNature local dev env. Copy to `.env.local` and fill in.
# Only EXPO_PUBLIC_* keys ship to the client bundle.

# OneSignal (push notifications)
# App ID is also embedded in app.json -> expo.extra.onesignalAppId so
# native dev builds can find it without a .env.
EXPO_PUBLIC_ONESIGNAL_APP_ID=f21e4ed4-1498-41ad-b8fb-20962763a6dd
EXPO_PUBLIC_NOTIFY_PROVIDER=onesignal

# Firebase config is in app.json -> expo.extra.firebase; no env needed.
