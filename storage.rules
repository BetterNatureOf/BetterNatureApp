rules_version = '2';

// Firebase Storage rules. Without these, the bucket defaults to
// "deny all writes" — which is why ID uploads silently failed.
//
// Deploy with:  firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // ── ID documents ──
    // Path shape (from authFirebase.js → uploadIdImage):
    //   id-docs/{kind}/{uid}-{side}-{timestamp}.jpg
    //
    // The user owns their own ID images. Anyone signed in can read,
    // because admins viewing the Verify IDs queue need to fetch the
    // download URLs — and Firebase Storage URLs are already capability
    // tokens (the unguessable ?token=... query param), so this is
    // effectively "you must have been handed a link."
    match /id-docs/{kind}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && filename.matches(request.auth.uid + '-.*')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Profile photos (future) ──
    // Same self-ownership rule. Not enforced anywhere yet but
    // pre-emptive so when avatar upload ships there's nothing to deploy.
    match /avatars/{uid}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
